rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isUser(uid) { return request.auth.uid == uid; }

    // True if this update touches ONLY the given top-level field(s).
    function onlyChanges(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /users/{uid} {
      allow read: if signedIn();          // tighten to friends-only if you can
      allow create: if isUser(uid);

      // You may fully edit your own profile. Any other signed-in user may ONLY:
      //   - add/remove a shared game in your `openGames` index, or
      //   - append to your `friends` list (mutual-friend handshake).
      // They can never touch any other field, and can never remove your friends.
      allow update: if isUser(uid)
        || (signedIn() && onlyChanges(['openGames']))
        || (signedIn() && onlyChanges(['friends'])
            && (!('friends' in resource.data)
                || request.resource.data.friends.hasAll(resource.data.friends)));

      allow delete: if isUser(uid);

      match /incomingRequests/{from} {
        allow read, delete: if isUser(uid);
        allow create: if signedIn() && request.auth.uid == from;
      }
    }

    match /usernames/{name} {
      allow read: if signedIn();
      allow create: if signedIn();        // ideally also assert it maps to your uid
    }

    match /games/{id} {
      allow read: if signedIn() && (resource.data.whiteUid == request.auth.uid
                                 || resource.data.blackUid == request.auth.uid);
      // The creator must be one of the two players in the game they create.
      allow create: if signedIn() && (request.resource.data.whiteUid == request.auth.uid
                                   || request.resource.data.blackUid == request.auth.uid);
      allow update: if signedIn() && (resource.data.whiteUid == request.auth.uid
                                   || resource.data.blackUid == request.auth.uid);
    }

    match /open_challenges/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;
      allow delete: if signedIn() && resource.data.hostUid == request.auth.uid;
    }
  }
}
